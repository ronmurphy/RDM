<?xml version="1.0" encoding="UTF-8"?>
<!-- RDM Desktop - labwc configuration
     Place this at ~/.config/labwc/rc.xml or merge with your existing config -->
<labwc_config>

  <core>
    <gap>4</gap>
    <adaptiveSync>no</adaptiveSync>
  </core>

  <theme>
    <name>RDM</name>
    <cornerRadius>8</cornerRadius>
    <font place="ActiveWindow">
      <name>Inter</name>
      <size>11</size>
    </font>
    <font place="InactiveWindow">
      <name>Inter</name>
      <size>11</size>
    </font>
  </theme>

  <snapping>
    <range>20</range>
    <topMaximize>yes</topMaximize>
  </snapping>

  <keyboard>
    <!-- App launcher (fires on release so Super+key combos work) -->
    <keybind key="Super_L" onRelease="yes">
      <action name="Execute" command="rdm-launcher" />
    </keybind>

    <!-- Terminal -->
    <keybind key="W-Return">
      <action name="Execute" command="foot" />
    </keybind>

    <!-- Window snapping: half-screen -->
    <keybind key="S-Left">
      <action name="SnapToEdge" direction="left" />
    </keybind>
    <keybind key="S-Right">
      <action name="SnapToEdge" direction="right" />
    </keybind>
    <keybind key="S-Up">
      <action name="SnapToEdge" direction="up" />
    </keybind>
    <keybind key="S-Down">
      <action name="SnapToEdge" direction="down" />
    </keybind>

    <!-- Maximize -->
    <keybind key="S-f">
      <action name="ToggleMaximize" />
    </keybind>

    <!-- Close window -->
    <keybind key="S-q">
      <action name="Close" />
    </keybind>

    <!-- Workspaces -->
    <keybind key="S-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="S-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="S-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="S-4">
      <action name="GoToDesktop" to="4" />
    </keybind>

    <!-- Move window to workspace -->
    <keybind key="S-S-1">
      <action name="SendToDesktop" to="1" follow="true" />
    </keybind>
    <keybind key="S-S-2">
      <action name="SendToDesktop" to="2" follow="true" />
    </keybind>
    <keybind key="S-S-3">
      <action name="SendToDesktop" to="3" follow="true" />
    </keybind>
    <keybind key="S-S-4">
      <action name="SendToDesktop" to="4" follow="true" />
    </keybind>

    <!-- ==================== Screenshots ==================== -->
    <!-- Super+S: select a region to capture -->
    <keybind key="W-s">
      <action name="Execute" command="rdm-screenshot region" />
    </keybind>
    <!-- Super+Shift+S: capture all monitors -->
    <keybind key="W-S-s">
      <action name="Execute" command="rdm-screenshot full" />
    </keybind>
    <!-- Print Screen: capture all monitors -->
    <keybind key="Print">
      <action name="Execute" command="rdm-screenshot full" />
    </keybind>

    <!-- ==================== Volume (multimedia keys) ==================== -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%%+" />
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%%-" />
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" />
    </keybind>
    <keybind key="XF86AudioMicMute">
      <action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle" />
    </keybind>

    <!-- ==================== Media playback ==================== -->
    <keybind key="XF86AudioPlay">
      <action name="Execute" command="playerctl play-pause" />
    </keybind>
    <keybind key="XF86AudioNext">
      <action name="Execute" command="playerctl next" />
    </keybind>
    <keybind key="XF86AudioPrev">
      <action name="Execute" command="playerctl previous" />
    </keybind>
  </keyboard>

  <desktops number="4">
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
    </names>
  </desktops>

</labwc_config>
