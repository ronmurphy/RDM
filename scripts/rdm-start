#!/bin/sh
# RDM Desktop - Session start script
# Launch with: rdm-start
# Or from a display manager / TTY: exec rdm-start

set -e

export XDG_CURRENT_DESKTOP=RDM
export XDG_SESSION_DESKTOP=RDM
export DESKTOP_SESSION=RDM
export XDG_SESSION_TYPE=wayland
export RDM_SESSION=1

# Portal: tell xdg-desktop-portal to use the wlr backend (screenshots, screencasting)
export XDG_CURRENT_DESKTOP="wlroots:RDM"

# Ensure config directory exists
RDM_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rdm"
mkdir -p "$RDM_CONFIG_DIR"

# Copy default configs if not present
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/../config/rdm.toml" ] && [ ! -f "$RDM_CONFIG_DIR/rdm.toml" ]; then
    cp "$SCRIPT_DIR/../config/rdm.toml" "$RDM_CONFIG_DIR/rdm.toml"
fi
if [ -f "$SCRIPT_DIR/../config/session.toml" ] && [ ! -f "$RDM_CONFIG_DIR/session.toml" ]; then
    cp "$SCRIPT_DIR/../config/session.toml" "$RDM_CONFIG_DIR/session.toml"
fi

# Copy labwc config if not present
LABWC_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/labwc"
mkdir -p "$LABWC_DIR"
if [ -f "$SCRIPT_DIR/../config/labwc-rc.xml" ] && [ ! -f "$LABWC_DIR/rc.xml" ]; then
    cp "$SCRIPT_DIR/../config/labwc-rc.xml" "$LABWC_DIR/rc.xml"
fi

# Deploy xdg-desktop-portal config so the wlr backend activates for RDM
PORTAL_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/xdg-desktop-portal"
mkdir -p "$PORTAL_DIR"
if [ -f "$SCRIPT_DIR/../config/rdm-portals.conf" ] && [ ! -f "$PORTAL_DIR/portals.conf" ]; then
    cp "$SCRIPT_DIR/../config/rdm-portals.conf" "$PORTAL_DIR/portals.conf"
fi

# labwc autostart file — launches rdm-session which manages everything else
AUTOSTART="$LABWC_DIR/autostart"
cat > "$AUTOSTART" << 'AUTOSTART_EOF'
#!/bin/sh
# RDM autostart — managed by rdm-start
# Only launch rdm-session when running as the RDM desktop environment
if [ "$RDM_SESSION" != "1" ]; then
    exit 0
fi
LOG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/rdm/rdm.log"
# Kill any zombie rdm-session from a previous incomplete logout, then start fresh
if pgrep -x rdm-session >/dev/null 2>&1; then
    pkill -x rdm-session 2>/dev/null || true
    sleep 0.5
fi
rdm-session >> "$LOG_FILE" 2>&1 &
AUTOSTART_EOF
chmod +x "$AUTOSTART"

echo "Starting RDM Desktop (labwc compositor)..."
exec labwc
